POST http://127.0.0.1:8000/chat
Content-Type: application/json
X-SoulDrive-Token: {{souldrive_token}}

{
  "query": "请详细解释 Transformer 模型的核心创新点是什么？它是如何解决传统 RNN 的缺陷的？",
  "top_k": 3
}

